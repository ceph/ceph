#!/bin/bash

# Export radosgw bucket usage metrics to a prometheus pushgateway endpoint.
#
# dependencies:
#   radosgw-admin, curl, jq
#
# environment variables:
#   PROMETHEUS_PUSHGATEWAY_ENDPOINT=http://pushgateway.example.org:9091/metrics/job/rgw-bucket-usage
#   PROMETHEUS_PUSHGATEWAY_ARGS="--user username:password"

rgw-format-bucket-usage | curl -X PUT --data-binary @- $PROMETHEUS_PUSHGATEWAY_ENDPOINT $PROMETHEUS_PUSHGATEWAY_ARGS
