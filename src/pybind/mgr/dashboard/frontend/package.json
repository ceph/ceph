    "stylelint": "16.20.0",
    "stylelint-config-standard": "38.0.0",
    "stylelint-scss": "6.12.1",
    "table": "6.8.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "validator": "13.15.23"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": "cypress/e2e/common"
  }
}
